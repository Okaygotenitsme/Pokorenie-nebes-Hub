local esp_thing = tab1:CreateButton({
   Name = "ESP",
   Callback = function()
      local plrsvc2 = game:GetService("Players")
      local runsvc2 = game:GetService("RunService")
      local myself = plrsvc2.LocalPlayer

      local boxcolor = Color3.fromRGB(255, 0, 0)
      local linecolor = Color3.fromRGB(255, 0, 0)
      local linethick = 0.2
      local boxsize = Vector3.new(5, 6, 3)

      local myfolder = workspace:FindFirstChild("PlayerVisuals") or Instance.new("Folder")
      myfolder.Name = "PlayerVisuals"
      myfolder.Parent = workspace

      local stufftable = {}

      local function killobj(obj)
         if obj and obj.Parent then
            obj:Destroy()
         end
      end

      local function getmyattach()
         local mychar2 = myself.Character
         if not mychar2 then return nil end
         local myroot = mychar2:FindFirstChild("HumanoidRootPart")
         if not myroot then return nil end
         local myatt = myroot:FindFirstChild("ESP_LocalAttachment")
         if not myatt then
            myatt = Instance.new("Attachment")
            myatt.Name = "ESP_LocalAttachment"
            myatt.Parent = myroot
         end
         return myatt
      end

      local function makebillboard(whoplayer, whohum)
         local bb = Instance.new("BillboardGui")
         bb.Name = whoplayer.Name .. "_Billboard"
         bb.AlwaysOnTop = true
         bb.Size = UDim2.new(0, 200, 0, 40)
         bb.StudsOffset = Vector3.new(0, 5, 0)

         local namelbl = Instance.new("TextLabel")
         namelbl.BackgroundTransparency = 1
         namelbl.Size = UDim2.new(1, 0, 0.5, 0)
         namelbl.TextColor3 = Color3.fromRGB(255, 255, 255)
         namelbl.TextStrokeTransparency = 0
         namelbl.Font = Enum.Font.GothamBold
         namelbl.TextScaled = true
         namelbl.Text = whoplayer.DisplayName
         namelbl.Parent = bb

         local hplbl = Instance.new("TextLabel")
         hplbl.BackgroundTransparency = 1
         hplbl.Position = UDim2.new(0, 0, 0.5, 0)
         hplbl.Size = UDim2.new(1, 0, 0.5, 0)
         hplbl.TextColor3 = Color3.fromRGB(255, 80, 80)
         hplbl.TextStrokeTransparency = 0
         hplbl.Font = Enum.Font.GothamBold
         hplbl.TextScaled = true
         hplbl.Text = "Health: 0"
         hplbl.Parent = bb

         whohum.HealthChanged:Connect(function()
            hplbl.Text = "Health: " .. math.floor(whohum.Health)
         end)
         hplbl.Text = "Health: " .. math.floor(whohum.Health)

         return bb
      end

      local function removestuff(whoplayer)
         local v = stufftable[whoplayer]
         if not v then return end
         for _, obj in pairs(v) do killobj(obj) end
         stufftable[whoplayer] = nil
      end

      local function addstuff(whoplayer)
         if whoplayer == myself then return end

         local hischar = whoplayer.Character or whoplayer.CharacterAdded:Wait()
         local hisroot = hischar:WaitForChild("HumanoidRootPart")
         local hishum = hischar:WaitForChild("Humanoid")

         removestuff(whoplayer)

         local mybox = Instance.new("BoxHandleAdornment")
         mybox.Name = whoplayer.Name .. "_ESP_Cube"
         mybox.Adornee = hisroot
         mybox.AlwaysOnTop = true
         mybox.Size = boxsize
         mybox.Color3 = boxcolor
         mybox.Transparency = 0.5
         mybox.ZIndex = 10
         mybox.Parent = myfolder

         local myatt2 = getmyattach()
         local hisatt = Instance.new("Attachment")
         hisatt.Parent = hisroot

         local mybeam = Instance.new("Beam")
         mybeam.Name = whoplayer.Name .. "_ESP_Beam"
         mybeam.Attachment0 = hisatt
         mybeam.Attachment1 = myatt2
         mybeam.Color = ColorSequence.new(linecolor)
         mybeam.Transparency = NumberSequence.new(0.3)
         mybeam.Width0 = linethick
         mybeam.Width1 = linethick
         mybeam.FaceCamera = true
         mybeam.LightEmission = 1
         mybeam.Parent = myfolder

         local mybillboard = makebillboard(whoplayer, hishum)
         mybillboard.Parent = hisroot

         stufftable[whoplayer] = { cube = mybox, beam = mybeam, billboard = mybillboard }
      end

      myself.CharacterAdded:Connect(function()
         task.wait(0.2)
         local freshatt = getmyattach()
         for _, v in pairs(stufftable) do
            if v.beam then
               v.beam.Attachment1 = freshatt
            end
         end
      end)

      local function setupdude(whoplayer)
         whoplayer.CharacterAdded:Connect(function()
            task.wait(0.1)
            addstuff(whoplayer)
         end)
         whoplayer.CharacterRemoving:Connect(function()
            removestuff(whoplayer)
         end)
         if whoplayer.Character then
            addstuff(whoplayer)
         end
      end

      plrsvc2.PlayerAdded:Connect(setupdude)
      plrsvc2.PlayerRemoving:Connect(removestuff)

      for _, dude in ipairs(plrsvc2:GetPlayers()) do
         if dude ~= myself then
            setupdude(dude)
         end
      end

      local creditgui = Instance.new("ScreenGui")
      creditgui.Name = "ESP_CreditGUI"
      creditgui.ResetOnSpawn = false
      creditgui.Parent = myself:WaitForChild("PlayerGui")

      local creditlbl = Instance.new("TextLabel")
      creditlbl.Size = UDim2.new(0, 300, 0, 30)
      creditlbl.Position = UDim2.new(0, 10, 0, 10)
      creditlbl.BackgroundTransparency = 1
      creditlbl.TextColor3 = Color3.fromRGB(255, 255, 255)
      creditlbl.TextStrokeTransparency = 0
      creditlbl.Font = Enum.Font.GothamBold
      creditlbl.TextScaled = true
      creditlbl.Text = "Made by: Meloten/Pokorenie nebes"
      creditlbl.Parent = creditgui
   end,
})

